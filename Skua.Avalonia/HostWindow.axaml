<Window xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Class="Skua.Avalonia.HostWindow" Title="{Binding Title}" Width="{Binding Width}" Height="{Binding Height}" WindowStartupLocation="CenterScreen">
    <ContentControl Content="{Binding}" />
</Window>
