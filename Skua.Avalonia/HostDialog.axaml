    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Class="Skua.Avalonia.HostDialog" Title="{Binding Title}" Width="400" SizeToContent="WidthAndHeight" WindowStartupLocation="CenterOwner" Topmost="True" CanResize="False">
