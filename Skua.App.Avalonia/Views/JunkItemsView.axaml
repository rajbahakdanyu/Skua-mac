<UserControl xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:Skua.Core.ViewModels;assembly=Skua.Core" x:Class="Skua.App.Avalonia.Views.JunkItemsView" x:DataType="vm:JunkItemsViewModel">
    <Grid RowDefinitions="Auto,*,Auto" Margin="8">
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
            <TextBlock Text="Junk Items" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
            <TextBlock VerticalAlignment="Center" Foreground="Gray">
                <Run Text="Total: " />
                <Run Text="{Binding TotalJunk}" />
            </TextBlock>
            <CheckBox Content="Skip Sell Warning" IsChecked="{Binding SkipSellWarning}" />
        </StackPanel>
        <ListBox Grid.Row="1" ItemsSource="{Binding Items}" SelectionMode="Multiple" x:Name="ItemsList">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <CheckBox IsChecked="{Binding IsSelected}" />
                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding Category}" VerticalAlignment="Center" FontSize="11" Foreground="Gray" />
                        <TextBlock Text="[JUNK]" VerticalAlignment="Center" Foreground="OrangeRed" FontWeight="Bold" IsVisible="{Binding IsJunk}" />
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
            <Button Content="Refresh" Command="{Binding RefreshCommand}" />
            <Button Content="Mark Junk" Command="{Binding MarkAsJunkCommand}" />
            <Button Content="Unmark" Command="{Binding UnmarkAsJunkCommand}" />
            <Button Content="Unmark All" Command="{Binding UnmarkAllJunkCommand}" />
            <Button Content="Sell All Junk" Command="{Binding SellAllJunkCommand}" />
        </StackPanel>
    </Grid>
</UserControl>
