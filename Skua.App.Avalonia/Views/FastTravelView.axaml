<UserControl xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:Skua.Core.ViewModels;assembly=Skua.Core" x:Class="Skua.App.Avalonia.Views.FastTravelView" x:DataType="vm:FastTravelViewModel">
    <Grid RowDefinitions="Auto,*,Auto" Margin="8">
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
            <CheckBox Content="Private Room" IsChecked="{Binding MapService.UsePrivateRoom}" />
            <TextBox Text="{Binding MapService.PrivateRoomNumber}" Width="60" Watermark="#" />
            <Button Content="Save" Command="{Binding SaveFastTravelsCommand}" />
            <Button Content="Clear" Command="{Binding ClearFastTravelsCommand}" />
        </StackPanel>
        <ScrollViewer Grid.Row="1">
            <ItemsControl ItemsSource="{Binding FastTravelItems}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:FastTravelItemViewModel">
                        <Border Margin="4" Padding="8" CornerRadius="4" Background="{DynamicResource SystemControlBackgroundListLowBrush}" MinWidth="130">
                            <StackPanel Spacing="2">
                                <TextBlock Text="{Binding DescriptionName}" FontWeight="SemiBold" />
                                <TextBlock FontSize="11" Foreground="Gray">
                                    <Run Text="{Binding MapName}" />
 -                                    <Run Text="{Binding Cell}" />
/                                    <Run Text="{Binding Pad}" />
                                </TextBlock>
                                <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,4,0,0">
                                    <Button Content="Go" Command="{Binding TravelCommand}" CommandParameter="{Binding}" Padding="6,2" />
                                    <Button Content="Edit" Command="{Binding EditCommand}" Padding="6,2" />
                                    <Button Content="✕" Command="{Binding RemoveCommand}" Padding="6,2" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
        <!-- Editor -->
        <Border Grid.Row="2" Padding="8" Margin="0,8,0,0" CornerRadius="4" Background="{DynamicResource SystemControlBackgroundListLowBrush}">
            <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,*,*,*,Auto">
                <TextBox Grid.Row="0" Grid.Column="0" Text="{Binding Editor.Travel.DescriptionName}" Watermark="Name" Margin="0,0,4,4" />
                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Editor.Travel.MapName}" Watermark="Map" Margin="4,0,4,4" />
                <TextBox Grid.Row="0" Grid.Column="2" Text="{Binding Editor.Travel.Cell}" Watermark="Cell" Margin="4,0,4,4" />
                <TextBox Grid.Row="0" Grid.Column="3" Text="{Binding Editor.Travel.Pad}" Watermark="Pad" Margin="4,0,0,4" />
                <StackPanel Grid.Row="1" Grid.ColumnSpan="5" Orientation="Horizontal" Spacing="8">
                    <Button Content="Get Current" Command="{Binding Editor.GetCurrentCommand}" />
                    <Button Content="Add" Command="{Binding AddFastTravelCommand}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
