<UserControl xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:Skua.Core.ViewModels;assembly=Skua.Core" x:Class="Skua.App.Avalonia.Views.AutoView" x:DataType="vm:AutoViewModel">
    <Grid RowDefinitions="Auto,Auto,Auto,Auto" Margin="8">
        <!-- Class selection -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,8">
            <ComboBox Grid.Column="0" ItemsSource="{Binding PlayerClasses}" SelectedItem="{Binding SelectedClass}" HorizontalAlignment="Stretch" />
            <Button Grid.Column="1" Content="Reload" Command="{Binding ReloadClassesCommand}" Margin="8,0,0,0" />
        </Grid>
        <!-- Class mode -->
        <Grid Grid.Row="1" ColumnDefinitions="*,*" Margin="0,0,0,8">
            <StackPanel Grid.Column="0" Margin="0,0,4,0">
                <TextBlock Text="Use Mode" FontWeight="SemiBold" Margin="0,0,0,4" />
                <ComboBox ItemsSource="{Binding CurrentClassModeStrings}" SelectedItem="{Binding SelectedClassModeString}" HorizontalAlignment="Stretch" />
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="4,0,0,0">
                <TextBlock Text="Map IDs (optional)" FontWeight="SemiBold" Margin="0,0,0,4" />
                <TextBox Text="{Binding ManualMapIDs}" Watermark="e.g. 1234,5678" />
            </StackPanel>
        </Grid>
        <!-- Auto options -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="4" Margin="0,0,0,8">
            <CheckBox Content="Skip MP Check" IsChecked="{Binding Auto.SkipMPCheck}" />
        </StackPanel>
        <!-- Action buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8">
            <Button Content="Auto Attack" Command="{Binding StartAutoAttackCommand}" />
            <Button Content="Auto Hunt" Command="{Binding StartAutoHuntCommand}" />
            <Button Content="Stop" Command="{Binding StopAutoAsyncCommand}" />
        </StackPanel>
    </Grid>
</UserControl>
