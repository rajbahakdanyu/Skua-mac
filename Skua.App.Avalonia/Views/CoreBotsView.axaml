<UserControl xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:Skua.Core.ViewModels;assembly=Skua.Core" x:Class="Skua.App.Avalonia.Views.CoreBotsView" x:DataType="vm:CoreBotsViewModel">
    <Grid RowDefinitions="Auto,Auto,*" Margin="8">
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
            <TextBlock Text="Player:" VerticalAlignment="Center" />
            <TextBlock Text="{Binding CurrentPlayer}" FontWeight="SemiBold" VerticalAlignment="Center" />
            <Button Content="Load" Command="{Binding LoadCommand}" />
            <Button Content="Save" Command="{Binding SaveCommand}" />
        </StackPanel>
        <ListBox Grid.Row="1" ItemsSource="{Binding CoreBotsTabs}" SelectedItem="{Binding SelectedTab}" SelectionMode="Single" Margin="0,0,0,8">
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" Spacing="4" />
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding Header}" Padding="8,4" />
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        <ContentControl Grid.Row="2" Content="{Binding SelectedTab.Content}" />
    </Grid>
</UserControl>
