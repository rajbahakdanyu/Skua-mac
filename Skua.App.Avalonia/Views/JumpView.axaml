<UserControl xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:Skua.Core.ViewModels;assembly=Skua.Core" x:Class="Skua.App.Avalonia.Views.JumpView" x:DataType="vm:JumpViewModel">
    <Grid RowDefinitions="Auto,*,Auto" Margin="8">
        <Grid Grid.Row="0" ColumnDefinitions="*,*" Margin="0,0,0,8">
            <StackPanel Grid.Column="0" Margin="0,0,4,0">
                <TextBlock Text="Cell" FontWeight="SemiBold" Margin="0,0,0,4" />
                <ComboBox ItemsSource="{Binding Cells}" SelectedItem="{Binding SelectedCell}" HorizontalAlignment="Stretch" />
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="4,0,0,0">
                <TextBlock Text="Pad" FontWeight="SemiBold" Margin="0,0,0,4" />
                <ComboBox ItemsSource="{Binding Pads}" SelectedItem="{Binding SelectedPad}" HorizontalAlignment="Stretch" />
            </StackPanel>
        </Grid>
        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
            <Button Content="Jump" Command="{Binding JumpToCommand}" />
            <Button Content="Get Current" Command="{Binding GetCurrentCommand}" />
            <Button Content="Update Cells" Command="{Binding UpdateCellsCommand}" />
        </StackPanel>
    </Grid>
</UserControl>
