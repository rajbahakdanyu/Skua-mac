<UserControl xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:Skua.Core.ViewModels;assembly=Skua.Core" mc:Ignorable="d" d:DesignHeight="400" d:DesignWidth="350" x:Class="Skua.App.Avalonia.Views.LogTabView" x:DataType="vm:LogTabViewModel">
    <Grid RowDefinitions="*,Auto">
        <ListBox Grid.Row="0" ItemsSource="{Binding Logs}" />
        <Grid Grid.Row="1" ColumnDefinitions="*,*,*" Margin="0,4,0,0">
            <Button Grid.Column="0" Command="{Binding ClearLogCommand}" Content="Clear" HorizontalAlignment="Stretch" Margin="0,0,2,0" HorizontalContentAlignment="Center" />
            <Button Grid.Column="1" Command="{Binding CopyLogCommand}" Content="Copy" HorizontalAlignment="Stretch" Margin="2,0" HorizontalContentAlignment="Center" />
            <Button Grid.Column="2" Command="{Binding SaveLogCommand}" Content="Save" HorizontalAlignment="Stretch" Margin="2,0,0,0" HorizontalContentAlignment="Center" />
        </Grid>
    </Grid>
</UserControl>
