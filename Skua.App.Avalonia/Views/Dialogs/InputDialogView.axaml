<UserControl xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Skua.Core.ViewModels" x:Class="Skua.App.Avalonia.Views.Dialogs.InputDialogView" x:DataType="vm:InputDialogViewModel">
    <StackPanel Margin="16" Spacing="8" MinWidth="280">
        <TextBlock Text="{Binding DialogHint}" IsVisible="{Binding DialogHint, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" TextWrapping="Wrap" />
        <TextBox Text="{Binding DialogTextInput}" Watermark="{Binding TextBoxHint}" />
        <Grid ColumnDefinitions="*,*" Margin="0,8,0,0">
            <Button Grid.Column="0" Content="Confirm" Margin="0,0,4,0" Click="Confirm_Click" HorizontalAlignment="Stretch" />
            <Button Grid.Column="1" Content="Cancel" Margin="4,0,0,0" Click="Cancel_Click" HorizontalAlignment="Stretch" />
        </Grid>
    </StackPanel>
</UserControl>
