<UserControl xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Skua.Core.ViewModels" x:Class="Skua.App.Avalonia.Views.Dialogs.FastTravelEditorDialogView" x:DataType="vm:FastTravelEditorDialogViewModel">
    <StackPanel Margin="16" Spacing="8" MinWidth="300">
        <TextBox Text="{Binding Editor.Travel.DescriptionName}" Watermark="Description" />
        <TextBox Text="{Binding Editor.Travel.MapName}" Watermark="Map Name" />
        <Grid ColumnDefinitions="*,*" Margin="0,0,0,0">
            <TextBox Grid.Column="0" Text="{Binding Editor.Travel.Cell}" Watermark="Cell" Margin="0,0,4,0" />
            <TextBox Grid.Column="1" Text="{Binding Editor.Travel.Pad}" Watermark="Pad" Margin="4,0,0,0" />
        </Grid>
        <Button Content="Get Current Location" Command="{Binding Editor.GetCurrentCommand}" HorizontalAlignment="Stretch" />
        <Grid ColumnDefinitions="*,*" Margin="0,8,0,0">
            <Button Grid.Column="0" Content="Confirm" Margin="0,0,4,0" Click="Confirm_Click" HorizontalAlignment="Stretch" />
            <Button Grid.Column="1" Content="Cancel" Margin="4,0,0,0" Click="Cancel_Click" HorizontalAlignment="Stretch" />
        </Grid>
    </StackPanel>
</UserControl>
