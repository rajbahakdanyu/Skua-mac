<UserControl xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:Skua.Core.ViewModels;assembly=Skua.Core" x:Class="Skua.App.Avalonia.Views.ConsoleView" x:DataType="vm:ConsoleViewModel">
    <Grid RowDefinitions="*,Auto" Margin="8">
        <TextBox Grid.Row="0" Text="{Binding SnippetText}" AcceptsReturn="True" AcceptsTab="True" FontFamily="Consolas, Courier New, monospace" TextWrapping="Wrap" />
        <Button Grid.Row="1" Content="Run" Command="{Binding RunCommand}" HorizontalAlignment="Right" Margin="0,8,0,0" />
    </Grid>
</UserControl>
