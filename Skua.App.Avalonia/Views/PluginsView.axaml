<UserControl xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:Skua.Core.ViewModels;assembly=Skua.Core" x:Class="Skua.App.Avalonia.Views.PluginsView" x:DataType="vm:PluginsViewModel">
    <Grid RowDefinitions="Auto,*" Margin="8">
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
            <Button Content="Load Plugin" Command="{Binding LoadPluginCommand}" />
            <Button Content="Unload All" Command="{Binding UnloadAllPluginsCommand}" />
        </StackPanel>
        <ScrollViewer Grid.Row="1">
            <ItemsControl ItemsSource="{Binding Plugins}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,2" Padding="8" CornerRadius="4" Background="{DynamicResource SystemControlBackgroundListLowBrush}">
                            <Grid ColumnDefinitions="*,Auto">
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding Container.Plugin.Name}" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding Container.Plugin.Author}" FontSize="11" Foreground="Gray" />
                                    <TextBlock Text="{Binding Container.Plugin.Description}" FontSize="11" TextWrapping="Wrap" Margin="0,2,0,0" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                    <Button Content="Options" Command="{Binding EditPluginOptionsCommand}" IsVisible="{Binding HasOptions}" Padding="6,2" />
                                    <Button Content="Unload" Command="{Binding UnloadCommand}" Padding="6,2" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
