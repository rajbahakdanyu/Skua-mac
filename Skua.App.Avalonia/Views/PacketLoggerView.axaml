<UserControl xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:Skua.Core.ViewModels;assembly=Skua.Core" x:Class="Skua.App.Avalonia.Views.PacketLoggerView" x:DataType="vm:PacketLoggerViewModel">
    <Grid ColumnDefinitions="*,200" Margin="8">
        <!-- Left: logs -->
        <Grid Grid.Column="0" RowDefinitions="*,Auto" Margin="0,0,8,0">
            <ListBox Grid.Row="0" ItemsSource="{Binding PacketLogs}" SelectionMode="Multiple">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" FontFamily="Consolas, Courier New, monospace" FontSize="11" />
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
            <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                <Button Content="Clear" Command="{Binding ClearPacketLogsCommand}" />
                <Button Content="Save" Command="{Binding SavePacketLogsCommand}" />
                <ToggleButton Content="Logging" IsChecked="{Binding IsReceivingPackets}" />
            </StackPanel>
        </Grid>
        <!-- Right: filters -->
        <Grid Grid.Column="1" RowDefinitions="Auto,*,Auto">
            <TextBlock Grid.Row="0" Text="Filters" FontWeight="SemiBold" Margin="0,0,0,4" />
            <ScrollViewer Grid.Row="1">
                <ItemsControl ItemsSource="{Binding PacketFilters}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <CheckBox Content="{Binding Content}" IsChecked="{Binding IsChecked}" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
            <Button Grid.Row="2" Content="Clear Filters" Command="{Binding ClearFiltersCommand}" Margin="0,4,0,0" />
        </Grid>
    </Grid>
</UserControl>
