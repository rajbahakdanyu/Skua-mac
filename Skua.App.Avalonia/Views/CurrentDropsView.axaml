<UserControl xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:Skua.Core.ViewModels;assembly=Skua.Core" x:Class="Skua.App.Avalonia.Views.CurrentDropsView" x:DataType="vm:CurrentDropsViewModel">
    <Grid RowDefinitions="*,Auto" Margin="8">
        <ListBox Grid.Row="0" ItemsSource="{Binding CurrentDrops}" SelectedItem="{Binding SelectedDrop}" SelectionMode="Multiple" x:Name="DropsList">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding Name}" />
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
            <Button Content="Pickup Selected" Command="{Binding PickupSelectedCommand}" />
            <Button Content="Pickup All" Command="{Binding PickupAllCommand}" />
            <Button Content="Pickup AC" Command="{Binding PickupACCommand}" />
        </StackPanel>
    </Grid>
</UserControl>
